# Rust / Cargo
target/
Cargo.lock

# Environment secrets — never commit these
.env
.env.contracts
.env.local

# Optimized WASM outputs
*.optimized.wasm
*.wasm

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Kiro IDE
.kiro/

# Pull-request drafts
pr-*.md

# Bindings — generated src/ and compiled dist/ are not committed.
# Only package.json and tsconfig.json scaffolds are tracked.
bindings/*/src/
bindings/*/dist/
bindings/*/node_modules/

# Test snapshots (Soroban / insta crate)
**/__snapshots__/
*.snap
*.snap.new

# Generated / temporary files
*.bak
*.orig
*.log
*.tmp
.env.contracts
